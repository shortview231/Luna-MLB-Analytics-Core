{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "luna_comms/schemas/outbound_job.schema.json",
  "title": "Luna Comms Outbound Job",
  "type": "object",
  "required": [
    "job_id",
    "job_type",
    "schema_version",
    "state",
    "created_at",
    "updated_at",
    "idempotency_key",
    "correlation_id",
    "source",
    "routing",
    "payload",
    "status"
  ],
  "properties": {
    "job_id": {"type": "string"},
    "job_type": {"type": "string", "enum": ["email", "calendar_sync", "notification_update"]},
    "schema_version": {"type": "string"},
    "state": {
      "type": "string",
      "enum": ["detected", "prepared", "queued", "sent", "acknowledged", "archived", "failed", "dead_letter"]
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "idempotency_key": {"type": "string"},
    "correlation_id": {"type": "string"},
    "source": {"type": "object"},
    "routing": {"type": "object"},
    "payload": {"type": "object"},
    "status": {"type": "object"}
  },
  "additionalProperties": true
}
